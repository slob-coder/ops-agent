# ═══════════════════════════════════════════════════════════════
# OpsAgent Docker 环境变量配置
# ═══════════════════════════════════════════════════════════════
#
# 使用方法:
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 填写下面的配置
#   3. 启动:  docker compose up -d
#
# ═══════════════════════════════════════════════════════════════

# ── 必填 ──────────────────────────────────────────────────────

# LLM API Key（必填）
# Anthropic: sk-ant-...  |  OpenAI: sk-...  |  智谱: ...
OPS_LLM_API_KEY=

# ── LLM 配置 ─────────────────────────────────────────────────

# LLM 提供商（默认 anthropic）
# 可选: anthropic | openai | zhipu
OPS_LLM_PROVIDER=anthropic

# 模型名称（默认使用提供商的推荐模型）
# Anthropic: claude-sonnet-4-20250514
# OpenAI: gpt-4o
# 智谱: glm-4-plus
# OPS_LLM_MODEL=

# 自定义 API 地址（一般不用填，除非用代理或私有部署）
# OPS_LLM_BASE_URL=

# ── 目标配置 ─────────────────────────────────────────────────
# Agent 监控哪台服务器？支持 4 种类型:
#   local    — 容器自身（Demo 用）
#   ssh      — 远程 Linux 服务器
#   docker   — Docker 主机
#   k8s      — Kubernetes 集群

# 目标类型（默认 local）
OPS_TARGET_TYPE=local

# 目标名称（随意起名，方便识别）
OPS_TARGET_NAME=local

# ── SSH 目标配置 ──────────────────────────────────────────────
# 如果 OPS_TARGET_TYPE=ssh，需要填写以下内容:

# SSH 地址，格式: 用户名@主机名或IP
# 例: ubuntu@10.0.0.10  root@prod.example.com
# OPS_TARGET_HOST=

# SSH 端口（默认 22）
# OPS_TARGET_PORT=22

# SSH 密钥路径（容器内路径，已挂载 ~/.ssh）
# 例: /root/.ssh/id_rsa
# OPS_TARGET_KEY_FILE=

# 服务器重要程度（默认 normal）
# 可选: low | normal | high | critical
# OPS_TARGET_CRITICALITY=normal

# 目标描述
# OPS_TARGET_DESCRIPTION=

# ── Docker 目标配置 ───────────────────────────────────────────
# 如果 OPS_TARGET_TYPE=docker:

# docker-compose.yaml 路径
# OPS_TARGET_COMPOSE_FILE=./docker-compose.yaml

# ── K8s 目标配置 ──────────────────────────────────────────────
# 如果 OPS_TARGET_TYPE=k8s:

# K8s 命名空间
# OPS_TARGET_NAMESPACE=default

# kubeconfig 路径
# OPS_TARGET_KUBECONFIG=/root/.kube/config

# ── 通知配置 ─────────────────────────────────────────────────

# 通知类型（默认 none）
# 可选: none | slack | dingtalk | feishu | feishu_app
OPS_NOTIFIER_TYPE=none

# Webhook URL（slack/dingtalk/feishu 类型时必填）
# feishu 示例: https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# OPS_NOTIFIER_WEBHOOK_URL=

# ── 飞书自建应用（feishu_app 类型时使用）──────────────────────
# 获取方式见 README.md 「飞书通知配置」章节
# OPS_FEISHU_APP_ID=
# OPS_FEISHU_APP_SECRET=
# OPS_FEISHU_CHAT_ID=

# ── 源码仓库（可选）──────────────────────────────────────────
# 配置后 Agent 可以定位源码 bug 并生成补丁

# OPS_REPO_NAME=backend
# OPS_REPO_PATH=/opt/src/backend
# OPS_REPO_URL=git@github.com:your-org/backend.git
# OPS_REPO_LANGUAGE=python
# OPS_REPO_BUILD_CMD=make build
# OPS_REPO_TEST_CMD=pytest
# OPS_REPO_DEPLOY_CMD=make deploy
